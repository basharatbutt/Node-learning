<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Media Upload</title>
    <!-- Bootstrap for nice UI -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; }
        .upload-card { max-width: 500px; margin: 80px auto; border: none; border-radius: 15px; }
        .card-header { background: #6c5ce7; color: white; border-radius: 15px 15px 0 0 !important; }
    </style>
</head>
<body>

<div class="container">
    <div class="card upload-card shadow">
        <div class="card-header p-4 text-center">
            <h3 class="mb-0">Upload Center</h3>
            <small>Upload your Images or Videos</small>
        </div>
        <div class="card-body p-4">
            <!-- IMPORTANT: enctype="multipart/form-data" must be here for files -->
            <form action="/upload" method="POST" enctype="multipart/form-data">
                
                <div class="mb-4">
                    <label for="fileInput" class="form-label fw-bold">Select File</label>
                    <!-- accept="image/*,video/*" filters files for the user -->
                    <input type="file" name="myMedia" id="fileInput" class="form-control" accept="image/*,video/*" required>
                    <div class="form-text">Supported formats: JPG, PNG, MP4, MKV</div>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">
                        Start Upload
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

</body>
</html>