<!DOCTYPE html>
<html>
<head>
    <title>View Contact</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
</head>
<body class="bg-light">

<div class="container mt-5">
    <div class="card mx-auto shadow" style="max-width: 600px;">
        <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Contact Details</h4>
            <a href="/" class="btn btn-light btn-sm">Back to List</a>
        </div>
        <div class="card-body">
            <div class="text-center mb-4">
                <!-- A simple circle with initials as a profile picture -->
                <div class="bg-secondary text-white rounded-circle d-inline-block pt-3" style="width: 80px; height: 80px; font-size: 2rem;">
                    <%= contact.firstName[0] %><%= contact.lastName[0] %>
                </div>
            </div>

            <ul class="list-group list-group-flush">
                <li class="list-group-item">
                    <strong>First Name:</strong> <%= contact.firstName %>
                </li>
                <li class="list-group-item">
                    <strong>Last Name:</strong> <%= contact.lastName %>
                </li>
                <li class="list-group-item">
                    <strong>Email Address:</strong> <%= contact.email %>
                </li>
                <li class="list-group-item">
                    <strong>Phone Number:</strong> <%= contact.phone %>
                </li>
            </ul>
        </div>
        <div class="card-footer text-center">
            <a href="/update-contact/<%= contact.id %>" class="btn btn-warning">Edit Contact</a>
        </div>
    </div>
</div>

</body>
</html>