<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact App</title>
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body { background-color: #f8f9fa; }
        .navbar-brand { color: #d9534f !important; font-weight: bold; text-transform: uppercase; }
        .card-header { background-color: #34495e; color: white; display: flex; justify-content: space-between; align-items: center; }
        .table thead { background-color: #f1f1f1; }
        .btn-action { border-radius: 50%; padding: 5px 8px; font-size: 0.8rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-light bg-white border-bottom mb-4">
    <div class="container">
        <a class="navbar-brand" href="/">Contact App</a>
    </div>
</nav>

<div class="container">
    <div class="card shadow-sm">
        <div class="card-header py-3">
            <h4 class="mb-0">All Contacts</h4>
            <a href="/add-contact" class="btn btn-success btn-sm"><i class="bi bi-plus-circle"></i> Add New</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="px-4">#</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% contacts.forEach(contact => { %>
                    <tr>
                        <td class="px-4 fw-bold"><%= contact.id %></td>
                        <td><%= contact.firstName %></td>
                        <td><%= contact.lastName %></td>
                        <td><%= contact.email %></td>
                        <td><%= contact.phone %></td>
                        <td class="text-center">
                            <a href="/show-contact/<%= contact.id %>" class="btn btn-outline-info btn-action"><i class="bi bi-eye"></i></a>
                            <a href="/update-contact/<%= contact.id %>" class="btn btn-outline-secondary btn-action"><i class="bi bi-pencil-square"></i></a>
                            <a href="/delete-contact/<%= contact.id %>" class="btn btn-outline-danger btn-action" onclick="return confirm('Delete this contact?')"><i class="bi bi-x-lg"></i></a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>

</body>
</html>